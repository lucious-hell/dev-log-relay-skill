{
  "name": "dev-log-relay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "relay": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "cli": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "tsx --test tests/*.test.ts",
